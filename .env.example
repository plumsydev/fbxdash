# ===========================================
# FreeboxOS Ultra Dashboard - Environment Variables
# ===========================================
#
# Copy this file to `.env` and adjust as needed.
# `.env` is loaded automatically by the backend (via dotenv) for `npm run dev` /
# `npm start`, and by Docker Compose when you pass `--env-file .env` (or just
# have a `.env` file next to docker-compose.yml, which Compose reads by default).
#
# Every variable below is optional — the app works with zero configuration
# using the defaults shown in comments.

# ---------- Server ----------

# Port the Express backend listens on.
# Dev default (via `npm run dev`): 3001
# Docker default: 3000 (set by the Dockerfile, do not override in Docker)
# PORT=3001

# Legacy alias for PORT, only used as a fallback if PORT is unset.
# SERVER_PORT=3001

# Environment mode. Set automatically to "production" by `npm run start:prod`
# and by the Docker image — do not set this manually for local dev.
# NODE_ENV=development

# ---------- Vite dev server (frontend, local dev only) ----------

# Port for the Vite dev server (frontend). Default: 3000
# VITE_PORT=3000

# ---------- Freebox connection ----------

# Freebox hostname. Default: mafreebox.freebox.fr
# Use your Freebox's local IP instead if mDNS resolution doesn't work on your network.
# FREEBOX_HOST=mafreebox.freebox.fr

# Full override of the Freebox base URL (takes precedence over FREEBOX_HOST).
# Default: https://<FREEBOX_HOST>
# FREEBOX_URL=https://mafreebox.freebox.fr

# Freebox local IP, used as a fallback/reference for local-network detection.
# Default: 192.168.1.254
# FREEBOX_LOCAL_IP=192.168.1.254

# Freebox API version to target. v14 is supported by all current models
# (Ultra, Delta, Pop, Revolution, Mini 4K). v15 adds file-listing pagination.
# Default: v14
# FREEBOX_API_VERSION=v14

# ---------- Freebox app registration (identifies this app to the Freebox) ----------

# Default: fr.freeboxos.dashboard
# FREEBOX_APP_ID=fr.freeboxos.dashboard

# Default: Freebox Dashboard
# FREEBOX_APP_NAME=Freebox Dashboard

# Default: 1.0.0
# FREEBOX_APP_VERSION=1.0.0

# Default: Dashboard Web App
# FREEBOX_DEVICE_NAME=Dashboard Web App

# ---------- Token storage ----------

# Path to the file where the Freebox API session token is persisted.
# Default: .freebox_token in the project root (local dev).
# In Docker this is set to /app/data/freebox_token.json and backed by a named volume.
# FREEBOX_TOKEN_FILE=.freebox_token

# ---------- Testing / development ----------

# Simulate a specific Freebox model without the matching hardware.
# One of: ultra, delta, pop, revolution
# Leave unset for real model auto-detection.
# MOCK_FREEBOX_MODEL=

# ---------- Docker Compose ----------

# Host port the dashboard is exposed on (docker-compose.yml / docker-compose.dev.yml).
# Default: 7505 (docker-compose.yml), 3000 (docker-compose.dev.yml)
# DASHBOARD_PORT=7505

# API server port exposed by docker-compose.dev.yml (hot-reload dev container only).
# Default: 3001
# SERVER_PORT=3001

# ---------- Frontend build-time ----------

# logo.dev API token used to fetch device-brand icons on the Network page.
# Get a free token at https://logo.dev — leave unset to disable brand icons.
# NOTE: this is a Vite build-time variable (import.meta.env.VITE_LOGO_DEV_TOKEN),
# it must be set BEFORE building the frontend (`npm run build` / `docker compose build`),
# setting it at container runtime has no effect.
# VITE_LOGO_DEV_TOKEN=
